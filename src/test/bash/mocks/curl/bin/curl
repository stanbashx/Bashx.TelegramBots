#!/usr/local/bin/bash

MOCKS_CURL_FORM_STRINGS=()

while [[ $# -gt 0 ]]; do
 case "$1" in
  -o) MOCKS_CURL_DST_PATH="$2"; shift 2;;
  -w) MOCKS_CURL_DST_FORMAT="$2"; shift 2;;
  --data) MOCKS_CURL_DATA="$2"; shift 2;;
  --form-string) MOCKS_CURL_FORM_STRINGS+=("$2"); shift 2;;
  *) shift;;
 esac
done

if [[ "${MOCKS_CURL_EXIT_CODE}" =~ ^[1-9][0-9]*$ ]]; then
 exit ${MOCKS_CURL_EXIT_CODE}
elif [[ -n "${MOCKS_CURL_EXIT_CODE}" ]]; then
 echo 'Wrong exit code!' >&2; exit 1
fi

if [[ -n "${MOCKS_CURL_DATA}" && -n "${MOCKS_CURL_DATA_PATH}" ]]; then
 printf '%s' "${MOCKS_CURL_DATA}" > "${MOCKS_CURL_DATA_PATH}" || exit 1; fi

if [[ -n "${MOCKS_CURL_DST_PATH}" ]]; then
 case "${MOCKS_CURL_DST_TYPE}" in
  'file') touch "${MOCKS_CURL_DST_PATH}" || exit 1;;
  'symlink') ln -s "${MOCKS_CURL_DST_PATH}" "${MOCKS_CURL_DST_PATH}" || exit 1;;
  'dir') mkdir -p "${MOCKS_CURL_DST_PATH}" || exit 1;;
  *) if [[ -n "${MOCKS_CURL_DST}" ]]; then
   printf '%s' "${MOCKS_CURL_DST}" > "${MOCKS_CURL_DST_PATH}" || exit 1; fi;;
 esac
fi

if [[ "${MOCKS_CURL_DST_FORMAT}" == '%{http_code}' ]]; then
 printf '%s' "${MOCKS_CURL_HTTP_CODE}"; fi

if [[ -n "${MOCKS_CURL_FORM_STRINGS_PATH}" ]]; then
 for MOCKS_CURL_FORM_STRING in "${MOCKS_CURL_FORM_STRINGS[@]}"; do
  echo "${MOCKS_CURL_FORM_STRING}" >> "${MOCKS_CURL_FORM_STRINGS_PATH}" || exit 1
 done
fi
